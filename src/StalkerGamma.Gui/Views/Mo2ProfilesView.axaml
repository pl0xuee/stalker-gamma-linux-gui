<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StalkerGamma.Gui.ViewModels"
             x:Class="StalkerGamma.Gui.Views.Mo2ProfilesView"
             x:DataType="vm:Mo2ProfilesViewModel">
    <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Classes="eyebrow" Text="MOD ORGANIZER"/>
            <TextBlock Classes="h1" Text="MO2 Profiles"/>
            <TextBlock Classes="muted" Text="{Binding CurrentProfileText}" Margin="0,6,0,0"/>
            <TextBlock Classes="muted" Text="{Binding StatusText}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12">
            <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
            <Button Content="Set as selected" Command="{Binding SetSelectedCommand}"/>
            <Button Content="Delete" Command="{Binding DeleteSelectedCommand}"/>
        </StackPanel>

        <ListBox Grid.Row="2" ItemsSource="{Binding Profiles}"
                 SelectedItem="{Binding SelectedProfile}"/>
    </Grid>
</UserControl>
