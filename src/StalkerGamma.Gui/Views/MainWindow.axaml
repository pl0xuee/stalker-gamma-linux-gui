<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StalkerGamma.Gui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="StalkerGamma.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1100" Height="720"
        Title="Stalker GAMMA">

    <DockPanel>
        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10,6" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Log"
                        Command="{Binding ToggleLogPaneCommand}" Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding IsBusy}" Margin="8,0,0,0"/>
                <ProgressBar DockPanel.Dock="Right" Width="180" Height="14"
                             Minimum="0" Maximum="1"
                             Value="{Binding OverallProgress}"
                             IsVisible="{Binding IsBusy}" Margin="8,0,0,0"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Log pane -->
        <Border DockPanel.Dock="Bottom" Height="180"
                IsVisible="{Binding LogPaneOpen}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <ListBox ItemsSource="{Binding LogLines}" FontFamily="monospace" FontSize="12"/>
        </Border>

        <!-- Sidebar -->
        <Border DockPanel.Dock="Left" Width="180" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <ListBox ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNavItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:NavItem">
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,8">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding Name}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Page content -->
        <ContentControl Content="{Binding SelectedNavItem.Page}" Margin="16"/>
    </DockPanel>
</Window>
