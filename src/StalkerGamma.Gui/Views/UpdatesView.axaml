<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StalkerGamma.Gui.ViewModels"
             x:Class="StalkerGamma.Gui.Views.UpdatesView"
             x:DataType="vm:UpdatesViewModel">
    <Grid RowDefinitions="Auto,Auto,*">
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Classes="eyebrow" Text="MAINTENANCE"/>
            <TextBlock Classes="h1" Text="Updates"/>
            <TextBlock Classes="muted" Text="{Binding SummaryText}" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12">
            <Button Content="Check for updates" Classes="accent" Command="{Binding CheckCommand}"/>
            <Button Content="Apply updates" Command="{Binding ApplyCommand}"/>
            <CheckBox Content="Minimal" IsChecked="{Binding Minimal}"/>
            <CheckBox Content="Preserve user.ltx" IsChecked="{Binding PreserveUserSettings}"/>
            <CheckBox Content="Preserve MCM" IsChecked="{Binding PreserveMcmSettings}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Updates}" IsReadOnly="True"
                  AutoGenerateColumns="False" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="110"/>
                <DataGridTextColumn Header="ADDON" Binding="{Binding AddonName}" Width="*"/>
                <DataGridTextColumn Header="INSTALLED" Binding="{Binding OldVersion}" Width="200"/>
                <DataGridTextColumn Header="AVAILABLE" Binding="{Binding NewVersion}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
